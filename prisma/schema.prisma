// Kula backend — Prisma schema (PostgreSQL)
// Generated as part of MongoDB → PostgreSQL migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  client
  chef
  creator
  admin
}

enum ChefStatus {
  pending
  approved
  rejected
  suspended
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
}

enum EscrowStatus {
  held
  released
  refunded
}

enum OrderStatus {
  placed
  confirmed
  preparing
  ready
  delivered
  cancelled
}

enum FulfillmentType {
  delivery
  pickup
}

enum GroceryListStatus {
  pending_approval
  approved
  purchased
  reimbursed
}

enum GroceryPaymentMethod {
  app_payment
  chef_pays
  client_handles
}

enum PostType {
  photo
  video
  recipe
  daily_special
}

enum HashtagCategory {
  occasion
  cuisine
  diet
  technique
  general
}

enum MessageType {
  text
  image
  system
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

// ─────────────────────────────────────────────────────────────────────────────
// User + child tables
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  role         UserRole @default(client)
  avatar       String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  fcmToken     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dietaryRestrictions UserDietaryRestriction[]
  allergies           UserAllergy[]
  addressBook         UserAddress[]

  chefProfile         Chef?
  bookingsAsClient    Booking[]              @relation("BookingClient")
  ordersAsClient      Order[]                @relation("OrderClient")
  groceryListsAsClient GroceryList[]         @relation("GroceryListClient")
  posts               Post[]
  comments            Comment[]
  conversations       ConversationParticipant[]
  messages            Message[]
  notifications       Notification[]
  reviewsAsClient     Review[]               @relation("ReviewClient")
  relatedNotifications Notification[]        @relation("NotificationRelatedUser")
}

model UserDietaryRestriction {
  id          String @id @default(uuid())
  userId      String
  restriction String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restriction])
  @@index([userId])
}

model UserAllergy {
  id      String @id @default(uuid())
  userId  String
  allergy String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, allergy])
  @@index([userId])
}

model UserAddress {
  id         String   @id @default(uuid())
  userId     String
  label      String?
  address    String
  city       String
  state      String?
  postalCode String?
  country    String?
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Chef + child tables
// ─────────────────────────────────────────────────────────────────────────────

model Chef {
  id              String     @id @default(uuid())
  userId          String     @unique
  bio             String?
  location        String?
  status          ChefStatus @default(pending)
  rating          Float      @default(0)
  reviewCount     Int        @default(0)
  bookingCount    Int        @default(0)
  instantBooking  Boolean    @default(false)
  minRate         Float?     // denormalized — recomputed from pricing rows for sorting
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  cuisineTypes    ChefCuisineType[]
  mealCategories  ChefMealCategory[]
  signatureDishes ChefSignatureDish[]
  serviceTypes    ChefServiceType[]
  certifications  ChefCertification[]
  pricing         ChefPricing[]
  availability    ChefAvailabilitySlot[]
  blockOutDates   ChefBlockOutDate[]
  pinnedPosts     ChefPinnedPost[]

  bookings        Booking[]
  orders          Order[]
  groceryLists    GroceryList[]
  reviews         Review[]
  relatedNotifications Notification[] @relation("NotificationRelatedChef")

  @@index([status])
  @@index([rating])
}

model ChefCuisineType {
  id      String @id @default(uuid())
  chefId  String
  cuisine String

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@unique([chefId, cuisine])
  @@index([cuisine])
}

model ChefMealCategory {
  id           String @id @default(uuid())
  chefId       String
  mealCategory String

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@unique([chefId, mealCategory])
  @@index([mealCategory])
}

model ChefSignatureDish {
  id     String @id @default(uuid())
  chefId String
  dish   String

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@index([chefId])
}

model ChefServiceType {
  id          String @id @default(uuid())
  chefId      String
  serviceType String

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@unique([chefId, serviceType])
  @@index([serviceType])
}

model ChefBlockOutDate {
  id     String   @id @default(uuid())
  chefId String
  date   DateTime

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@unique([chefId, date])
  @@index([chefId])
}

model ChefCertification {
  id               String   @id @default(uuid())
  chefId           String
  name             String
  issuingAuthority String?
  year             Int?
  certificateUrl   String?
  createdAt        DateTime @default(now())

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@index([chefId])
}

model ChefPricing {
  id       String  @id @default(uuid())
  chefId   String
  hireType String
  rate     Float
  currency String  @default("USD")

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@unique([chefId, hireType])
  @@index([chefId])
  @@index([hireType])
  @@index([rate])
}

model ChefAvailabilitySlot {
  id          String    @id @default(uuid())
  chefId      String
  dayOfWeek   DayOfWeek
  startTime   String    // "HH:MM" 24-hr
  endTime     String
  isAvailable Boolean   @default(true)

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)

  @@index([chefId])
}

model ChefPinnedPost {
  chefId    String
  postId    String
  sortOrder Int    @default(0)

  chef Chef @relation(fields: [chefId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([chefId, postId])
  @@index([chefId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Booking
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                  String        @id @default(uuid())
  clientId            String
  chefId              String
  serviceType         String
  hireType            String
  date                DateTime
  timeSlot            String?
  numberOfGuests      Int
  // location (was embedded { address, city, coordinates })
  locationAddress     String
  locationCity        String
  locationLat         Float?
  locationLng         Float?
  occasion            String?
  specialInstructions String?
  status              BookingStatus @default(pending)
  totalAmount         Float
  platformFee         Float?
  paymentIntentId     String?
  escrowStatus        EscrowStatus  @default(held)
  reference           String?       @unique
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  client User @relation("BookingClient", fields: [clientId], references: [id])
  chef   Chef @relation(fields: [chefId], references: [id])

  groceryList   GroceryList?
  reviews       Review[]
  conversations Conversation[]
  relatedNotifications Notification[] @relation("NotificationRelatedBooking")

  @@index([clientId])
  @@index([chefId])
  @@index([status])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order + child tables
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                String          @id @default(uuid())
  clientId          String
  chefId            String
  fulfillmentType   FulfillmentType
  // deliveryAddress (optional, embedded)
  deliveryAddress   String?
  deliveryCity      String?
  deliveryLat       Float?
  deliveryLng       Float?
  pickupTime        DateTime?
  subtotal          Float
  deliveryFee       Float           @default(0)
  platformFee       Float?
  total             Float
  status            OrderStatus     @default(placed)
  paymentIntentId   String?
  reference         String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  client User @relation("OrderClient", fields: [clientId], references: [id])
  chef   Chef @relation(fields: [chefId], references: [id])

  items OrderItem[]
  relatedNotifications Notification[] @relation("NotificationRelatedOrder")

  @@index([clientId])
  @@index([chefId])
  @@index([status])
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  menuItemId String?
  name       String
  quantity   Int
  unitPrice  Float
  total      Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// GroceryList + items
// ─────────────────────────────────────────────────────────────────────────────

model GroceryList {
  id              String               @id @default(uuid())
  bookingId       String               @unique
  chefId          String
  clientId        String
  estimatedTotal  Float
  status          GroceryListStatus    @default(pending_approval)
  receiptUrl      String?
  actualTotal     Float?
  paymentMethod   GroceryPaymentMethod @default(app_payment)
  budgetCap       Float?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  chef    Chef    @relation(fields: [chefId], references: [id])
  client  User    @relation("GroceryListClient", fields: [clientId], references: [id])

  items GroceryItem[]

  @@index([chefId])
  @@index([clientId])
  @@index([status])
}

model GroceryItem {
  id             String @id @default(uuid())
  groceryListId  String
  name           String
  quantity       String
  estimatedCost  Float

  groceryList GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)

  @@index([groceryListId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Feed: Post, Comment + child tables
// ─────────────────────────────────────────────────────────────────────────────

model Post {
  id                    String   @id @default(uuid())
  authorId              String
  type                  PostType
  caption               String?
  dailySpecialPrice     Float?
  dailySpecialExpiresAt DateTime?
  likeCount             Int      @default(0)
  commentCount          Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  media      PostMedia[]
  hashtags   PostHashtag[]
  comments   Comment[]
  pinnedBy   ChefPinnedPost[]
  relatedNotifications Notification[] @relation("NotificationRelatedPost")

  @@index([authorId])
  @@index([type])
  @@index([isActive])
}

model PostMedia {
  id        String @id @default(uuid())
  postId    String
  url       String
  sortOrder Int    @default(0)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostHashtag {
  postId    String
  hashtagId String

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
}

model Comment {
  id         String   @id @default(uuid())
  postId     String
  authorId   String
  text       String
  isFlagged  Boolean  @default(false)
  flagReason String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Hashtag
// ─────────────────────────────────────────────────────────────────────────────

model Hashtag {
  id         String          @id @default(uuid())
  name       String          @unique
  useCount   Int             @default(0)
  category   HashtagCategory @default(general)
  isActive   Boolean         @default(true)
  isBanned   Boolean         @default(false)
  isFeatured Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  posts PostHashtag[]

  @@index([category])
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id                 String   @id @default(uuid())
  bookingId          String?
  lastMessageId      String?  @unique
  isRequestAccepted  Boolean  @default(false)
  isRequestDeclined  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  booking      Booking?                  @relation(fields: [bookingId], references: [id])
  lastMessage  Message?                  @relation("ConversationLastMessage", fields: [lastMessageId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]                 @relation("ConversationMessages")

  @@index([bookingId])
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  text           String?
  mediaUrl       String?
  type           MessageType @default(text)
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  conversation       Conversation  @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  sender             User          @relation(fields: [senderId], references: [id])
  lastMessageOf      Conversation? @relation("ConversationLastMessage")

  @@index([conversationId])
  @@index([senderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Normalized "data" — nullable FKs to related entities.
  relatedBookingId String?
  relatedOrderId   String?
  relatedPostId    String?
  relatedReviewId  String?
  relatedChefId    String?
  relatedUserId    String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedBooking Booking? @relation("NotificationRelatedBooking", fields: [relatedBookingId], references: [id])
  relatedOrder   Order?   @relation("NotificationRelatedOrder", fields: [relatedOrderId], references: [id])
  relatedPost    Post?    @relation("NotificationRelatedPost", fields: [relatedPostId], references: [id])
  relatedReview  Review?  @relation("NotificationRelatedReview", fields: [relatedReviewId], references: [id])
  relatedChef    Chef?    @relation("NotificationRelatedChef", fields: [relatedChefId], references: [id])
  relatedUser    User?    @relation("NotificationRelatedUser", fields: [relatedUserId], references: [id])

  @@index([userId])
  @@index([isRead])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reviews
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id                   String   @id @default(uuid())
  clientId             String
  chefId               String
  bookingId            String
  rating               Int      // 1..5 (enforced at app layer)
  comment              String?
  // categories (was embedded { foodQuality?, punctuality?, cleanliness?, communication? })
  categoryFoodQuality  Int?
  categoryPunctuality  Int?
  categoryCleanliness  Int?
  categoryCommunication Int?
  chefResponse         String?
  isFlagged            Boolean  @default(false)
  flagReason           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  client  User    @relation("ReviewClient", fields: [clientId], references: [id])
  chef    Chef    @relation(fields: [chefId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])
  relatedNotifications Notification[] @relation("NotificationRelatedReview")

  @@index([clientId])
  @@index([chefId])
  @@index([bookingId])
  @@index([isFlagged])
}
